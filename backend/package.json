{
  "name": "drive-together-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "Backend for drive-together carpooling app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_ENV=development node --import tsx --env-file-if-exists=../.env ./src/server.ts",
    "dev:watch": "NODE_ENV=development node --watch-path=./src --import tsx --env-file-if-exists=../.env ./src/server.ts",
    "start": "NODE_ENV=production node --env-file-if-exists=../.env dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.3",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "shared": "*"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.10.0",
    "tsx": "^4.7.0"
  }
}
