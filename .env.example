# Copy to .env and adjust as needed. .env is git-ignored.

# Node environment: development | production
NODE_ENV=development

# Backend (Single-Port: app + API share this port)
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0

# Database (SQLite file). A relative path is resolved against the repo root,
# regardless of the working directory the backend is started from.
DATABASE_PATH=./data/app.db

# Logging
LOG_LEVEL=info
